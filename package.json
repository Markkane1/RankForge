{
  "name": "rankforge",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:validate": "prisma validate --schema packages/database/prisma/schema.prisma",
    "check:rls": "node scripts/check-rls-coverage.js",
    "check:routes": "node scripts/check-route-guards.js",
    "check:route-reachability": "node scripts/check-route-reachability.js",
    "check:worker-tenant": "node scripts/check-worker-tenant.js",
    "check:lifecycle": "node scripts/check-lifecycle-orchestration.js",
    "check:offboarding": "node scripts/check-offboarding-proof.js",
    "check:approvals": "node scripts/check-approval-guards.js",
    "check:tasks": "node scripts/check-task-orchestration.js",
    "check:oauth-callback": "node scripts/check-oauth-callback-proof.js",
    "check:multi-location-gbp": "node scripts/check-multi-location-gbp.js",
    "check:geo-grid-lineage": "node scripts/check-geo-grid-lineage.js",
    "check:competitor-policy-source": "node scripts/check-competitor-policy-source.js",
    "check:external-research-lineage": "node scripts/check-external-research-lineage.js",
    "check:photo-storage": "node scripts/check-photo-storage-proof.js",
    "check:post-generation": "node scripts/check-post-generation-proof.js",
    "check:review-generation": "node scripts/check-review-generation-proof.js",
    "check:faq-monitoring": "node scripts/check-faq-monitoring-proof.js",
    "check:booking-url": "node scripts/check-booking-url-proof.js",
    "check:freshness-alert": "node scripts/check-freshness-alert-proof.js",
    "check:monthly-report": "node scripts/check-monthly-report-proof.js",
    "check:measurement-ingestion": "node scripts/check-measurement-ingestion.js",
    "check:conversion-elements": "node scripts/check-conversion-elements-proof.js",
    "check:content-pipeline": "node scripts/check-content-pipeline-proof.js",
    "check:anomaly-alerts": "node scripts/check-anomaly-alert-proof.js",
    "check:self-correction": "node scripts/check-self-correction-proof.js",
    "check:citation-workflow": "node scripts/check-citation-workflow-proof.js",
    "check:backlink-secondary": "node scripts/check-backlink-secondary-proof.js",
    "check:site-engine": "node scripts/check-site-engine-proof.js",
    "check:ui-validation": "node scripts/check-ui-validation-proof.js",
    "check:bundle-size": "npm run check:bundle-size --workspace=web",
    "check:scheduler-cadence": "node scripts/check-scheduler-cadence-proof.js",
    "check:health-proof": "node scripts/check-health-proof.js",
    "check:failed-tasks": "node scripts/check-failed-task-proof.js",
    "check:auth-cookies": "node scripts/check-auth-cookies.js",
    "check:env": "node scripts/check-env-validation.js",
    "check:audit": "node scripts/check-dependency-audit.js",
    "check:production-mocks": "node scripts/check-production-mock-fallbacks.js",
    "check:req-ids": "node scripts/check-requirement-ids.js",
    "check": "npm run db:validate && npm run check:rls && npm run check:routes && npm run check:route-reachability && npm run check:worker-tenant && npm run check:lifecycle && npm run check:offboarding && npm run check:approvals && npm run check:tasks && npm run check:oauth-callback && npm run check:multi-location-gbp && npm run check:geo-grid-lineage && npm run check:competitor-policy-source && npm run check:external-research-lineage && npm run check:photo-storage && npm run check:post-generation && npm run check:review-generation && npm run check:faq-monitoring && npm run check:booking-url && npm run check:freshness-alert && npm run check:monthly-report && npm run check:measurement-ingestion && npm run check:conversion-elements && npm run check:content-pipeline && npm run check:anomaly-alerts && npm run check:self-correction && npm run check:citation-workflow && npm run check:backlink-secondary && npm run check:site-engine && npm run check:ui-validation && npm run check:bundle-size && npm run check:scheduler-cadence && npm run check:health-proof && npm run check:failed-tasks && npm run check:auth-cookies && npm run check:env && npm run check:audit && npm run check:production-mocks && npm run check:req-ids && npm run lint && npm test && npm run build",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "latest"
  },
  "packageManager": "npm@10.8.1"
}
